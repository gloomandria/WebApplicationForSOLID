@model ProjetScolariteSOLID.ViewModels.InscriptionsViewModel
@{
    ViewData["Title"] = "Inscriptions";
}

<div id="app-data"
     data-controller="Inscriptions"
     data-current-page="@Model.CurrentPage"></div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>📋 Inscriptions</h1>
    <button type="button" class="btn btn-primary" id="btn-open-create">+ Nouvelle inscription</button>
</div>

<div id="alert-zone"></div>

<div class="table-responsive">
    <table class="table table-hover align-middle" id="inscriptions-table">
        <thead class="table-primary">
            <tr>
                <th>Étudiant</th>
                <th>Classe</th>
                <th>Date d'inscription</th>
                <th>Statut</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody id="table-body">
            @await Html.PartialAsync("_InscriptionsTable", Model)
        </tbody>
    </table>
</div>

<div class="d-flex justify-content-between align-items-center" id="pagination-zone">
    <small class="text-muted" id="pagination-info">
        @Model.Inscriptions.TotalCount inscription(s) — Page @Model.Inscriptions.Page / @Model.Inscriptions.TotalPages
    </small>
    <nav>
        <ul class="pagination mb-0" id="pagination-links">
            @if (Model.Inscriptions.HasPreviousPage)
            {
                <li class="page-item"><a class="page-link ajax-page" href="#" data-page="@(Model.CurrentPage - 1)">‹</a></li>
            }
            @for (int p = 1; p <= Model.Inscriptions.TotalPages; p++)
            {
                <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
                    <a class="page-link ajax-page" href="#" data-page="@p">@p</a>
                </li>
            }
            @if (Model.Inscriptions.HasNextPage)
            {
                <li class="page-item"><a class="page-link ajax-page" href="#" data-page="@(Model.CurrentPage + 1)">›</a></li>
            }
        </ul>
    </nav>
</div>

<!-- Modal : Nouvelle inscription -->
<div class="modal fade" id="modal-create" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">📋 Nouvelle inscription</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <form id="form-create">
                @Html.AntiForgeryToken()
                <div class="modal-body" id="modal-create-body"><div class="text-center py-3"><div class="spinner-border spinner-border-sm"></div></div></div>
                <div class="modal-footer">
                    <div id="modal-create-alert" class="text-danger me-auto small"></div>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-primary">Inscrire</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal : Modifier le statut -->
<div class="modal fade" id="modal-edit-statut" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">✏️ Modifier le statut</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <form id="form-edit-statut">
                @Html.AntiForgeryToken()
                <div class="modal-body" id="modal-edit-body"><div class="text-center py-3"><div class="spinner-border spinner-border-sm"></div></div></div>
                <div class="modal-footer">
                    <div id="modal-edit-alert" class="text-danger me-auto small"></div>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-warning">Enregistrer</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal : Supprimer -->
<div class="modal fade" id="modal-delete" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title text-danger">🗑️ Supprimer l'inscription</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <form id="form-delete">
                @Html.AntiForgeryToken()
                <div class="modal-body" id="modal-delete-body"><div class="text-center py-3"><div class="spinner-border spinner-border-sm"></div></div></div>
                <div class="modal-footer">
                    <div id="modal-delete-alert" class="text-danger me-auto small"></div>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-danger">Confirmer la suppression</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {    <script src="~/js/inscriptions.js" asp-append-version="true"></script>
}
