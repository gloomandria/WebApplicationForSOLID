@model ProjetScolariteSOLID.ViewModels.ClassesViewModel

@if (!Model.Classes.Any())
{
    <tr><td colspan="6"><div class="alert alert-info mb-0">Aucune classe enregistrée.</div></td></tr>
}
else
{
    @foreach (var c in Model.Classes)
    {
        <tr>
            <td>@c.Nom</td>
            <td><span class="badge bg-success">@c.Niveau</span></td>
            <td>@c.Filiere</td>
            <td>@c.AnneeAcademique</td>
            <td class="text-center">@c.CapaciteMax</td>
            <td class="text-end">
                <button type="button" class="btn btn-sm btn-outline-warning btn-edit" data-id="@c.Id">Éditer</button>
                <button type="button" class="btn btn-sm btn-outline-danger btn-delete" data-id="@c.Id">Supprimer</button>
            </td>
        </tr>
    }
}
