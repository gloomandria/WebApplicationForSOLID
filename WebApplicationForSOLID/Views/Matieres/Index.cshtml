@model ProjetScolariteSOLID.ViewModels.MatieresViewModel
@{
    ViewData["Title"] = "Matières";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>📚 Matières</h1>
    <button type="button" class="btn btn-warning" id="btn-open-create">+ Nouvelle matière</button>
</div>

<div id="alert-zone"></div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-warning">
            <tr>
                <th>Code</th>
                <th>Intitulé</th>
                <th class="text-center">Coefficient</th>
                <th class="text-center">Volume horaire</th>
                <th>Enseignant</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody id="table-body">
            @await Html.PartialAsync("_MatieresTable", Model)
        </tbody>
    </table>
</div>

<!-- Modal : Créer -->
<div class="modal fade" id="modal-create" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">📚 Nouvelle matière</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <form id="form-create">
                @Html.AntiForgeryToken()
                <div class="modal-body" id="modal-create-body"><div class="text-center py-3"><div class="spinner-border spinner-border-sm"></div></div></div>
                <div class="modal-footer">
                    <div id="modal-create-alert" class="text-danger me-auto small"></div>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-warning">Créer</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal : Éditer -->
<div class="modal fade" id="modal-edit" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">✏️ Modifier la matière</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <form id="form-edit">
                @Html.AntiForgeryToken()
                <div class="modal-body" id="modal-edit-body"><div class="text-center py-3"><div class="spinner-border spinner-border-sm"></div></div></div>
                <div class="modal-footer">
                    <div id="modal-edit-alert" class="text-danger me-auto small"></div>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-warning">Enregistrer</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal : Supprimer -->
<div class="modal fade" id="modal-delete" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title text-danger">🗑️ Supprimer la matière</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <form id="form-delete">
                @Html.AntiForgeryToken()
                <div class="modal-body" id="modal-delete-body"><div class="text-center py-3"><div class="spinner-border spinner-border-sm"></div></div></div>
                <div class="modal-footer">
                    <div id="modal-delete-alert" class="text-danger me-auto small"></div>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-danger">Confirmer</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function ($) {
    const token = () => $('input[name="__RequestVerificationToken"]').val() ?? '';

    function showAlert(msg, ok) {
        $('#alert-zone').html(
            `<div class="alert alert-${ok ? 'success' : 'danger'} alert-dismissible fade show" role="alert">${msg}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>`
        );
    }

    function refreshTable() {
        return $.get('/Matieres/Table')
            .done(html => { $('#table-body').html(html); bindRowButtons(); });
    }

    function loadModal(modalId, bodyId, url) {
        $('#' + bodyId).html('<div class="text-center py-3"><div class="spinner-border spinner-border-sm"></div></div>');
        bootstrap.Modal.getOrCreateInstance(document.getElementById(modalId)).show();
        return $.get(url)
            .done(html => $('#' + bodyId).html(html))
            .fail(() => {
                bootstrap.Modal.getInstance(document.getElementById(modalId)).hide();
                showAlert('Impossible de charger le formulaire.', false);
            });
    }

    function wireForm(formId, alertId, actionUrl, modalId) {
        const $form = $('#' + formId);
        $form[0].onsubmit = function (e) {
            e.preventDefault();
            $('#' + alertId).text('');
            const fd = new FormData($form[0]);
            $('#' + modalId + '-body').find('input,select,textarea').each(function () {
                if (this.name) fd.set(this.name, this.value);
            });
            $.ajax({
                url: actionUrl, method: 'POST', data: fd, processData: false, contentType: false,
                headers: { 'RequestVerificationToken': token() }
            }).done(data => {
                if (!data.success) { $('#' + alertId).text(data.message); return; }
                bootstrap.Modal.getInstance(document.getElementById(modalId)).hide();
                showAlert(data.message, true);
                refreshTable();
            }).fail(() => $('#' + alertId).text('Erreur serveur inattendue.'));
        };
    }

    $('#btn-open-create').on('click', function () {
        $('#modal-create-alert').text('');
        loadModal('modal-create', 'modal-create-body', '/Matieres/FormCreate')
            .done(() => wireForm('form-create', 'modal-create-alert', '/Matieres/CreateAjax', 'modal-create'));
    });

    function bindRowButtons() {
        $('.btn-edit').off('click').on('click', function () {
            $('#modal-edit-alert').text('');
            loadModal('modal-edit', 'modal-edit-body', '/Matieres/FormEdit?id=' + $(this).data('id'))
                .done(() => wireForm('form-edit', 'modal-edit-alert', '/Matieres/EditAjax', 'modal-edit'));
        });
        $('.btn-delete').off('click').on('click', function () {
            $('#modal-delete-alert').text('');
            loadModal('modal-delete', 'modal-delete-body', '/Matieres/FormDelete?id=' + $(this).data('id'))
                .done(() => wireForm('form-delete', 'modal-delete-alert', '/Matieres/DeleteAjax', 'modal-delete'));
        });
    }

    bindRowButtons();
}(jQuery));
</script>
}
