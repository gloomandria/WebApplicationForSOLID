@model ProjetScolariteSOLID.ViewModels.MatieresViewModel

<input type="hidden" name="Matiere.Id" value="@Model.Matiere.Id" />

<div class="row g-3">
    <div class="col-md-4">
        <label class="form-label">Code</label>
        <input name="Matiere.Code" value="@Model.Matiere.Code" class="form-control" required />
    </div>
    <div class="col-md-8">
        <label class="form-label">Intitulé</label>
        <input name="Matiere.Intitule" value="@Model.Matiere.Intitule" class="form-control" required />
    </div>
    <div class="col-12">
        <label class="form-label">Description</label>
        <textarea name="Matiere.Description" class="form-control" rows="2">@Model.Matiere.Description</textarea>
    </div>
    <div class="col-md-4">
        <label class="form-label">Coefficient</label>
        <input name="Matiere.Coefficient" value="@Model.Matiere.Coefficient" class="form-control" type="number" min="1" required />
    </div>
    <div class="col-md-4">
        <label class="form-label">Volume horaire</label>
        <input name="Matiere.VolumeHoraire" value="@Model.Matiere.VolumeHoraire" class="form-control" type="number" min="0" />
    </div>
    <div class="col-md-4">
        <label class="form-label">Enseignant</label>
        <select name="Matiere.EnseignantId" class="form-select">
            <option value="">— Aucun —</option>
            @foreach (var item in Model.EnseignantsList)
            {
                if (item.Value == Model.Matiere.EnseignantId?.ToString()) { <option value="@item.Value" selected>@item.Text</option> }
                else { <option value="@item.Value">@item.Text</option> }
            }
        </select>
    </div>
</div>
