@using ProjetScolariteSOLID.Domain.Models.Auth
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gestion Scolarité</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProjetScolariteSOLID.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.datatables.net/2.1.8/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/3.1.2/css/buttons.bootstrap5.min.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">🎓 Gestion Scolarité</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain"
                        aria-controls="navMain" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navMain">

                    @* ── Menu principal (visible uniquement si connecté) ── *@
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <ul class="navbar-nav me-auto">
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Home" asp-action="Index">📊 Tableau de bord</a>
                            </li>

                            @* Étudiants — Administrateur, Enseignant, Etudiant *@
                            @if (User.IsInRole(ApplicationRole.Administrateur) ||
                                 User.IsInRole(ApplicationRole.Enseignant) ||
                                 User.IsInRole(ApplicationRole.Etudiant))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Etudiants" asp-action="Index">🎓 Étudiants</a>
                                </li>
                            }

                            @* Enseignants — Administrateur, Enseignant *@
                            @if (User.IsInRole(ApplicationRole.Administrateur) ||
                                 User.IsInRole(ApplicationRole.Enseignant))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Enseignants" asp-action="Index">👨‍🏫 Enseignants</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Notes" asp-action="Index">📝 Notes</a>
                                </li>
                            }

                            @* Matières, Classes, Inscriptions — Administrateur + Enseignant *@
                            @if (User.IsInRole(ApplicationRole.Administrateur) ||
                                 User.IsInRole(ApplicationRole.Enseignant))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Matieres" asp-action="Index">📚 Matières</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Classes" asp-action="Index">🏫 Classes</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Inscriptions" asp-action="Index">📋 Inscriptions</a>
                                </li>
                            }

                            @* Référentiels — Administrateur uniquement *@
                            @if (User.IsInRole(ApplicationRole.Administrateur))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link text-white dropdown-toggle" href="#" role="button"
                                       data-bs-toggle="dropdown" aria-expanded="false">
                                        🗂️ Référentiels
                                    </a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" asp-controller="Referentiels" asp-action="Index" asp-route-type="AnneesAcademiques">📅 Années académiques</a></li>
                                        <li><a class="dropdown-item" asp-controller="Referentiels" asp-action="Index" asp-route-type="Filieres">🎓 Filières</a></li>
                                        <li><a class="dropdown-item" asp-controller="Referentiels" asp-action="Index" asp-route-type="Grades">🏅 Grades</a></li>
                                        <li><a class="dropdown-item" asp-controller="Referentiels" asp-action="Index" asp-route-type="Niveaux">📊 Niveaux</a></li>
                                        <li><a class="dropdown-item" asp-controller="Referentiels" asp-action="Index" asp-route-type="Specialites">🔬 Spécialités</a></li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li><a class="dropdown-item" asp-controller="Referentiels" asp-action="Index" asp-route-type="StatutsInscription">📌 Statuts d'inscription</a></li>
                                        <li><a class="dropdown-item" asp-controller="Referentiels" asp-action="Index" asp-route-type="TypesEvaluation">📝 Types d'évaluation</a></li>
                                    </ul>
                                </li>

                                @* Back-office Admin *@
                                <li class="nav-item dropdown">
                                    <a class="nav-link text-warning dropdown-toggle fw-semibold" href="#" role="button"
                                       data-bs-toggle="dropdown" aria-expanded="false">
                                        ⚙️ Administration
                                    </a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index">🏠 Back-office</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Users">👥 Utilisateurs</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Permissions">🔐 Permissions</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="EmailQueue">📧 File d'emails</a></li>
                                        <li><a class="dropdown-item" asp-controller="Audit" asp-action="Index">🕵️ Journal d'audit</a></li>
                                    </ul>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <ul class="navbar-nav me-auto"></ul>
                    }

                    @* ── Barre utilisateur (droite) ── *@
                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link text-white dropdown-toggle" href="#" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    👤 @User.Identity.Name
                                    @if (User.IsInRole(ApplicationRole.Administrateur))
                                    { <span class="badge bg-warning text-dark ms-1">Admin</span> }
                                    else if (User.IsInRole(ApplicationRole.Enseignant))
                                    { <span class="badge bg-info text-dark ms-1">Enseignant</span> }
                                    else if (User.IsInRole(ApplicationRole.Etudiant))
                                    { <span class="badge bg-success ms-1">Étudiant</span> }
                                    else if (User.IsInRole(ApplicationRole.Visiteur))
                                    { <span class="badge bg-secondary ms-1">Visiteur</span> }
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            <button type="submit" class="dropdown-item text-danger">🚪 Se déconnecter</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Account" asp-action="Login">🔑 Connexion</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Account" asp-action="Register">✏️ S'inscrire</a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        @if (TempData["Success"] is string success)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @success
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] is string error)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @error
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container py-2">
            &copy; @DateTime.Now.Year — Gestion Scolarité | Principes SOLID appliqués en .NET 10
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/2.1.8/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.1.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/ajax-helpers.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
