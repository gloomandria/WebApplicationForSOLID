@model ProjetScolariteSOLID.ViewModels.EtudiantsViewModel
@{
    ViewData["Title"] = "Étudiants";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>👨‍🎓 Étudiants</h1>
    <button type="button" class="btn btn-primary" id="btn-open-create">+ Nouvel étudiant</button>
</div>

<div id="alert-zone"></div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-primary">
            <tr>
                <th>N° Étudiant</th>
                <th>Nom complet</th>
                <th>Email</th>
                <th>Téléphone</th>
                <th>Date naissance</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody id="table-body">
            @await Html.PartialAsync("_EtudiantsTable", Model)
        </tbody>
    </table>
</div>

<div class="d-flex justify-content-between align-items-center">
    <small class="text-muted">@Model.Etudiants.TotalCount étudiant(s) — Page @Model.Etudiants.Page / @Model.Etudiants.TotalPages</small>
    <nav>
        <ul class="pagination mb-0" id="pagination-links">
            @if (Model.Etudiants.HasPreviousPage)
            {
                <li class="page-item"><a class="page-link ajax-page" href="#" data-page="@(Model.CurrentPage - 1)">‹</a></li>
            }
            @for (int i = 1; i <= Model.Etudiants.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link ajax-page" href="#" data-page="@i">@i</a>
                </li>
            }
            @if (Model.Etudiants.HasNextPage)
            {
                <li class="page-item"><a class="page-link ajax-page" href="#" data-page="@(Model.CurrentPage + 1)">›</a></li>
            }
        </ul>
    </nav>
</div>

<!-- Modal : Créer -->
<div class="modal fade" id="modal-create" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">👨‍🎓 Nouvel étudiant</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <form id="form-create">
                @Html.AntiForgeryToken()
                <div class="modal-body" id="modal-create-body"><div class="text-center py-3"><div class="spinner-border spinner-border-sm"></div></div></div>
                <div class="modal-footer">
                    <div id="modal-create-alert" class="text-danger me-auto small"></div>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-primary">Créer</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal : Éditer -->
<div class="modal fade" id="modal-edit" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">✏️ Modifier l'étudiant</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <form id="form-edit">
                @Html.AntiForgeryToken()
                <div class="modal-body" id="modal-edit-body"><div class="text-center py-3"><div class="spinner-border spinner-border-sm"></div></div></div>
                <div class="modal-footer">
                    <div id="modal-edit-alert" class="text-danger me-auto small"></div>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-warning">Enregistrer</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal : Supprimer -->
<div class="modal fade" id="modal-delete" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title text-danger">🗑️ Supprimer l'étudiant</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <form id="form-delete">
                @Html.AntiForgeryToken()
                <div class="modal-body" id="modal-delete-body"><div class="text-center py-3"><div class="spinner-border spinner-border-sm"></div></div></div>
                <div class="modal-footer">
                    <div id="modal-delete-alert" class="text-danger me-auto small"></div>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-danger">Confirmer</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal : Détails -->
<div class="modal fade" id="modal-details" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">👤 Détails</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body" id="modal-details-body"><div class="text-center py-3"><div class="spinner-border spinner-border-sm"></div></div></div>
            <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fermer</button></div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function ($) {
    let currentPage = @Model.CurrentPage;
    const token = () => $('input[name="__RequestVerificationToken"]').val() ?? '';

    function showAlert(msg, ok) {
        $('#alert-zone').html(
            `<div class="alert alert-${ok ? 'success' : 'danger'} alert-dismissible fade show" role="alert">${msg}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>`
        );
    }

    function refreshTable(page) {
        return $.get('/Etudiants/Table', { page })
            .done(html => {
                $('#table-body').html(html);
                bindRowButtons();
            });
    }

    function loadModal(modalId, bodyId, url) {
        $('#' + bodyId).html('<div class="text-center py-3"><div class="spinner-border spinner-border-sm"></div></div>');
        bootstrap.Modal.getOrCreateInstance(document.getElementById(modalId)).show();
        return $.get(url)
            .done(html => $('#' + bodyId).html(html))
            .fail(() => {
                bootstrap.Modal.getInstance(document.getElementById(modalId)).hide();
                showAlert('Impossible de charger le formulaire.', false);
            });
    }

    function wireForm(formId, alertId, actionUrl, modalId) {
        const $form = $('#' + formId);
        $form[0].onsubmit = function (e) {
            e.preventDefault();
            $('#' + alertId).text('');
            const fd = new FormData($form[0]);
            $('#' + modalId + '-body').find('input,select,textarea').each(function () {
                if (this.name) fd.set(this.name, this.value);
            });
            $.ajax({
                url: actionUrl,
                method: 'POST',
                data: fd,
                processData: false,
                contentType: false,
                headers: { 'RequestVerificationToken': token() }
            }).done(data => {
                if (!data.success) { $('#' + alertId).text(data.message); return; }
                bootstrap.Modal.getInstance(document.getElementById(modalId)).hide();
                showAlert(data.message, true);
                refreshTable(currentPage);
            }).fail(() => $('#' + alertId).text('Erreur serveur inattendue.'));
        };
    }

    $('#btn-open-create').on('click', function () {
        $('#modal-create-alert').text('');
        loadModal('modal-create', 'modal-create-body', '/Etudiants/FormCreate')
            .done(() => wireForm('form-create', 'modal-create-alert', '/Etudiants/CreateAjax', 'modal-create'));
    });

    function bindRowButtons() {
        $('.btn-details').off('click').on('click', function () {
            loadModal('modal-details', 'modal-details-body', '/Etudiants/FormDetails?id=' + $(this).data('id'));
        });
        $('.btn-edit').off('click').on('click', function () {
            $('#modal-edit-alert').text('');
            loadModal('modal-edit', 'modal-edit-body', '/Etudiants/FormEdit?id=' + $(this).data('id'))
                .done(() => wireForm('form-edit', 'modal-edit-alert', '/Etudiants/EditAjax', 'modal-edit'));
        });
        $('.btn-delete').off('click').on('click', function () {
            $('#modal-delete-alert').text('');
            loadModal('modal-delete', 'modal-delete-body', '/Etudiants/FormDelete?id=' + $(this).data('id'))
                .done(() => wireForm('form-delete', 'modal-delete-alert', '/Etudiants/DeleteAjax', 'modal-delete'));
        });
    }

    $('#pagination-links').on('click', '.ajax-page', function (e) {
        e.preventDefault();
        currentPage = parseInt($(this).data('page'), 10);
        refreshTable(currentPage);
    });

    bindRowButtons();
}(jQuery));
</script>
}
