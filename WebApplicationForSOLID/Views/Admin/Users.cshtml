@model ProjetScolariteSOLID.ViewModels.Admin.UserListViewModel
@{
    ViewData["Title"] = "Gestion des utilisateurs";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0">👥 Utilisateurs</h2>
        <small class="text-muted">@Model.Users.Count utilisateur(s) enregistré(s)</small>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back-office</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-3">Nom</th>
                        <th>Email</th>
                        <th>Rôle</th>
                        <th class="text-center">Email</th>
                        <th class="text-center">Statut</th>
                        <th>Créé le</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var u in Model.Users)
                {
                    <tr>
                        <td class="ps-3 fw-semibold">@u.NomComplet</td>
                        <td class="text-muted small">@u.Email</td>
                        <td>
                            <span class="badge rounded-pill bg-secondary">@u.Role</span>
                        </td>
                        <td class="text-center">
                            @if (u.EmailConfirme)
                            {
                                <span class="badge rounded-pill bg-success">✓ Confirmé</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-warning text-dark">⏳ En attente</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (u.EstActif)
                            {
                                <span class="badge rounded-pill bg-success">● Actif</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-danger">● Inactif</span>
                            }
                        </td>
                        <td class="text-muted small">@u.DateCreation.ToString("dd/MM/yyyy")</td>
                        <td class="text-end pe-3">
                            <div class="d-flex justify-content-end gap-1 flex-wrap">
                                <a asp-action="AssignRole" asp-route-userId="@u.Id"
                                   class="btn btn-sm btn-outline-primary" title="Gérer le rôle">
                                    🎭 Rôle
                                </a>
                                <button type="button"
                                        class="btn btn-sm @(u.EstActif ? "btn-outline-danger" : "btn-outline-success") btn-toggle-active"
                                        data-user-id="@u.Id"
                                        data-user-name="@u.NomComplet"
                                        data-action-label="@(u.EstActif ? "désactiver" : "activer")"
                                        title="@(u.EstActif ? "Désactiver le compte" : "Activer le compte")">
                                    @(u.EstActif ? "🔒 Désactiver" : "🔓 Activer")
                                </button>
                                <button type="button"
                                        class="btn btn-sm btn-outline-info btn-send-validation"
                                        data-user-id="@u.Id"
                                        data-user-name="@u.NomComplet"
                                        data-user-email="@u.Email"
                                        title="Envoyer un email d'activation avec lien de définition de mot de passe">
                                    ✉️ Valider
                                </button>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- ── Modal : Activer / Désactiver ──────────────────────────────────── -->
<div class="modal fade" id="modal-toggle" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-bottom" id="modal-toggle-header">
                <h5 class="modal-title" id="modal-toggle-title">Confirmer</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center py-4">
                <div class="fs-1 mb-2" id="modal-toggle-icon">❓</div>
                <p class="mb-1">
                    Êtes-vous sûr de vouloir <strong id="modal-toggle-action"></strong>
                    le compte de <strong id="modal-toggle-user"></strong> ?
                </p>
                <small class="text-muted">Un email sera envoyé à l'utilisateur pour l'informer.</small>
            </div>
            <div class="modal-footer border-top bg-light">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
                <form asp-action="ToggleActive" method="post" id="form-toggle" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="userId" id="toggle-userId" />
                    <button type="submit" class="btn px-4" id="modal-toggle-btn">Confirmer</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- ── Modal : Envoi de validation ───────────────────────────────────── -->
<div class="modal fade" id="modal-validation" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-bottom bg-info bg-opacity-10">
                <h5 class="modal-title">✉️ Envoyer un email de validation</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center py-4">
                <div class="fs-1 mb-2">📨</div>
                <p class="mb-1">
                    Un email contenant un <strong>lien d'activation</strong> et de définition de mot de passe
                    sera envoyé à :
                </p>
                <p class="fw-semibold mb-0" id="modal-validation-user"></p>
                <small class="text-muted" id="modal-validation-email"></small>
            </div>
            <div class="modal-footer border-top bg-light">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
                <form asp-action="SendValidation" method="post" id="form-validation" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="userId" id="validation-userId" />
                    <button type="submit" class="btn btn-info px-4">✉️ Envoyer</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    'use strict';

    var toggleModal     = new bootstrap.Modal(document.getElementById('modal-toggle'));
    var validationModal = new bootstrap.Modal(document.getElementById('modal-validation'));

    // ── Toggle Activer / Désactiver ──────────────────────────────────
    document.querySelectorAll('.btn-toggle-active').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var isDeactivate = this.dataset.actionLabel === 'désactiver';

            document.getElementById('toggle-userId').value        = this.dataset.userId;
            document.getElementById('modal-toggle-action').textContent = this.dataset.actionLabel;
            document.getElementById('modal-toggle-user').textContent   = this.dataset.userName;
            document.getElementById('modal-toggle-icon').textContent   = isDeactivate ? '🔒' : '🔓';
            document.getElementById('modal-toggle-title').textContent  = isDeactivate ? 'Désactiver le compte' : 'Activer le compte';

            var header = document.getElementById('modal-toggle-header');
            header.className = 'modal-header border-bottom ' + (isDeactivate ? 'bg-danger bg-opacity-10' : 'bg-success bg-opacity-10');

            var btn2 = document.getElementById('modal-toggle-btn');
            btn2.className = 'btn px-4 ' + (isDeactivate ? 'btn-danger' : 'btn-success');
            btn2.textContent = isDeactivate ? '🔒 Désactiver' : '🔓 Activer';

            toggleModal.show();
        });
    });

    // ── Envoi Validation ─────────────────────────────────────────────
    document.querySelectorAll('.btn-send-validation').forEach(function (btn) {
        btn.addEventListener('click', function () {
            document.getElementById('validation-userId').value            = this.dataset.userId;
            document.getElementById('modal-validation-user').textContent  = this.dataset.userName;
            document.getElementById('modal-validation-email').textContent = this.dataset.userEmail;
            validationModal.show();
        });
    });
})();
</script>
}
