@model ProjetScolariteSOLID.ViewModels.Admin.UserListViewModel
@{
    ViewData["Title"] = "Gestion des utilisateurs";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>👥 Utilisateurs</h2>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Back-office</a>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Nom</th>
                <th>Email</th>
                <th>Rôle</th>
                <th>Email confirmé</th>
                <th>Statut</th>
                <th>Créé le</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var u in Model.Users)
        {
            <tr>
                <td>@u.NomComplet</td>
                <td>@u.Email</td>
                <td><span class="badge bg-secondary">@u.Role</span></td>
                <td>
                    @if (u.EmailConfirme)
                    { <span class="badge bg-success">✓ Confirmé</span> }
                    else
                    { <span class="badge bg-warning text-dark">En attente</span> }
                </td>
                <td>
                    @if (u.EstActif)
                    { <span class="badge bg-success">Actif</span> }
                    else
                    { <span class="badge bg-danger">Inactif</span> }
                </td>
                <td>@u.DateCreation.ToString("dd/MM/yyyy")</td>
                <td>
                    <a asp-action="AssignRole" asp-route-userId="@u.Id"
                       class="btn btn-sm btn-outline-primary me-1">Rôle</a>
                    <form asp-action="ToggleActive" method="post" class="d-inline"
                          onsubmit="return confirm('Confirmer ?')">
                        <input type="hidden" name="userId" value="@u.Id" />
                        <button type="submit" class="btn btn-sm @(u.EstActif ? "btn-outline-danger" : "btn-outline-success")">
                            @(u.EstActif ? "Désactiver" : "Activer")
                        </button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
