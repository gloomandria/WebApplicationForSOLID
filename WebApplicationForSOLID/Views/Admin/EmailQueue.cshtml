@model ProjetScolariteSOLID.ViewModels.Admin.EmailQueueListViewModel
@using ProjetScolariteSOLID.Domain.Models.Auth
@{
    ViewData["Title"] = "File d'emails";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📧 File d'emails</h2>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Back-office</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Destinataire</th>
                <th>Sujet</th>
                <th>Statut</th>
                <th>Tentatives</th>
                <th>Créé le</th>
                <th>Envoyé le</th>
                <th>Erreur</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var e in Model.Emails)
        {
            <tr>
                <td>@e.Id</td>
                <td>@e.Destinataire</td>
                <td>@e.Sujet</td>
                <td>
                    @switch (e.Statut)
                    {
                        case EmailStatut.EnAttente:
                            <span class="badge bg-warning text-dark">En attente</span>
                            break;
                        case EmailStatut.Envoye:
                            <span class="badge bg-success">Envoyé</span>
                            break;
                        case EmailStatut.Echoue:
                            <span class="badge bg-danger">Échoué</span>
                            break;
                    }
                </td>
                <td>@e.NbTentatives</td>
                <td>@e.DateCreation.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@(e.DateEnvoi?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                <td class="text-danger small">@(e.MessageErreur ?? string.Empty)</td>
            </tr>
        }
        </tbody>
    </table>
</div>

@if (Model.TotalPages > 1)
{
    <nav>
        <ul class="pagination pagination-sm">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link" asp-action="EmailQueue" asp-route-page="@i">@i</a>
                </li>
            }
        </ul>
    </nav>
}
