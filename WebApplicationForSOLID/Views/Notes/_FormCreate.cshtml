@model ProjetScolariteSOLID.ViewModels.NotesViewModel

<div class="row g-3">
    <div class="col-md-6">
        <label class="form-label">Étudiant</label>
        <select name="Note.EtudiantId" class="form-select" required>
            <option value="">— Choisir —</option>
            @foreach (var item in Model.EtudiantsList) { <option value="@item.Value">@item.Text</option> }
        </select>
    </div>
    <div class="col-md-6">
        <label class="form-label">Matière</label>
        <select name="Note.MatiereId" class="form-select" required>
            <option value="">— Choisir —</option>
            @foreach (var item in Model.MatieresList) { <option value="@item.Value">@item.Text</option> }
        </select>
    </div>
    <div class="col-md-4">
        <label class="form-label">Note /20</label>
        <input name="Note.Valeur" class="form-control" type="number" step="0.01" min="0" max="20" required />
    </div>
    <div class="col-md-4">
        <label class="form-label">Type d'évaluation</label>
        <select name="Note.TypeEvaluationId" class="form-select" required>
            <option value="">— Choisir —</option>
            @foreach (var item in Model.TypesEvalList) { <option value="@item.Value">@item.Text</option> }
        </select>
    </div>
    <div class="col-md-4">
        <label class="form-label">Date</label>
        <input name="Note.Date" class="form-control" type="date" required />
    </div>
    <div class="col-12">
        <label class="form-label">Commentaire</label>
        <input name="Note.Commentaire" class="form-control" />
    </div>
</div>
