@model ProjetScolariteSOLID.ViewModels.ReferentielViewModel
@{
    ViewData["Title"] = Model.NomReferentiel;
    var type = ViewData["Type"] as string ?? string.Empty;
}

<div id="app-data"
     data-controller="Referentiels"
     data-ref-type="@type"></div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>@Model.Icone @Model.NomReferentiel</h1>
    <button type="button" class="btn btn-success" id="btn-open-create">+ Nouvel élément</button>
</div>

<div id="alert-zone"></div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-primary">
            <tr>
                <th>#</th>
                <th>Libellé</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody id="table-body">
            @await Html.PartialAsync("_Table", Model)
        </tbody>
    </table>
</div>
<small class="text-muted">@Model.Items.Count élément(s)</small>

<!-- Modal : Créer -->
<div class="modal fade" id="modal-create" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@Model.Icone Nouvel élément</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="form-create">
                @Html.AntiForgeryToken()
                <div class="modal-body" id="modal-create-body">
                    <div class="text-center py-3"><div class="spinner-border spinner-border-sm"></div></div>
                </div>
                <div class="modal-footer">
                    <div id="modal-create-alert" class="text-danger me-auto small"></div>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-success">Créer</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal : Éditer -->
<div class="modal fade" id="modal-edit" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">✏️ Modifier l'élément</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="form-edit">
                @Html.AntiForgeryToken()
                <div class="modal-body" id="modal-edit-body">
                    <div class="text-center py-3"><div class="spinner-border spinner-border-sm"></div></div>
                </div>
                <div class="modal-footer">
                    <div id="modal-edit-alert" class="text-danger me-auto small"></div>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-warning">Enregistrer</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal : Supprimer -->
<div class="modal fade" id="modal-delete" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-danger">🗑️ Supprimer l'élément</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="form-delete">
                @Html.AntiForgeryToken()
                <div class="modal-body" id="modal-delete-body">
                    <div class="text-center py-3"><div class="spinner-border spinner-border-sm"></div></div>
                </div>
                <div class="modal-footer">
                    <div id="modal-delete-alert" class="text-danger me-auto small"></div>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-danger">Confirmer</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {    <script src="~/js/referentiels.js" asp-append-version="true"></script>
}
