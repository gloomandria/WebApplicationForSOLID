@page
@model ErrorModel
@{
    ViewData["Title"] = "Erreur";
}

<h1 class="text-danger">Erreur.</h1>
<h2 class="text-danger">Une erreur est survenue lors du traitement de votre requête.</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>Identifiant de requête :</strong> <code>@Model.RequestId</code>
    </p>
}

<p>Veuillez réessayer ultérieurement. Si le problème persiste, contactez le support.</p>
