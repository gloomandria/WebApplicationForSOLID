@page
@model ProjetScolariteSOLID.Pages.Classes.CreateModel
@{
    ViewData["Title"] = "Nouvelle classe";
}

<h1>🏫 Nouvelle classe</h1>

<form method="post" class="mt-3" style="max-width:560px">
    <div asp-validation-summary="All" class="alert alert-danger" style="display:@(ViewContext.ModelState.IsValid ? "none" : "block")"></div>

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Classe.Nom" class="form-label"></label>
            <input asp-for="Classe.Nom" class="form-control" />
        </div>
        <div class="col-md-6">
            <label asp-for="Classe.NiveauId" class="form-label">Niveau</label>
            <select asp-for="Classe.NiveauId" asp-items="Model.NiveauxList" class="form-select">
                <option value="">— Choisir —</option>
            </select>
        </div>
        <div class="col-md-6">
            <label asp-for="Classe.FiliereId" class="form-label">Filière</label>
            <select asp-for="Classe.FiliereId" asp-items="Model.FilieresList" class="form-select">
                <option value="">— Choisir —</option>
            </select>
        </div>
        <div class="col-md-6">
            <label asp-for="Classe.AnneeAcademiqueId" class="form-label">Année académique</label>
            <select asp-for="Classe.AnneeAcademiqueId" asp-items="Model.AnneesAcadList" class="form-select">
                <option value="">— Choisir —</option>
            </select>
        </div>
        <div class="col-md-4">
            <label asp-for="Classe.CapaciteMax" class="form-label"></label>
            <input asp-for="Classe.CapaciteMax" class="form-control" type="number" min="1" />
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-success">Créer</button>
        <a asp-page="Index" class="btn btn-secondary">Annuler</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
