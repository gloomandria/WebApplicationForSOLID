@page "{id:int}"
@model ProjetScolariteSOLID.Pages.Classes.DeleteModel
@{
    ViewData["Title"] = "Supprimer la classe";
}

<h1 class="text-danger">🗑️ Supprimer la classe</h1>

<div class="alert alert-warning mt-3">
    Êtes-vous sûr de vouloir supprimer la classe <strong>@Model.Classe.Nom</strong> ?
    Cette action est irréversible.
</div>

<dl class="row" style="max-width:400px">
    <dt class="col-sm-5">Nom</dt>
    <dd class="col-sm-7">@Model.Classe.Nom</dd>
    <dt class="col-sm-5">Niveau</dt>
    <dd class="col-sm-7">@Model.Classe.Niveau</dd>
    <dt class="col-sm-5">Filière</dt>
    <dd class="col-sm-7">@Model.Classe.Filiere</dd>
    <dt class="col-sm-5">Année</dt>
    <dd class="col-sm-7">@Model.Classe.AnneeAcademique</dd>
    <dt class="col-sm-5">Capacité max.</dt>
    <dd class="col-sm-7">@Model.Classe.CapaciteMax</dd>
</dl>

<form method="post" class="d-flex gap-2">
    <button type="submit" class="btn btn-danger">Confirmer la suppression</button>
    <a asp-page="Index" class="btn btn-secondary">Annuler</a>
</form>
