@page
@model ProjetScolariteSOLID.Pages.Classes.IndexModel
@{
    ViewData["Title"] = "Classes";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>🏫 Classes</h1>
    <a asp-page="Create" class="btn btn-success">+ Nouvelle classe</a>
</div>

@if (!Model.Classes.Any())
{
    <div class="alert alert-info">Aucune classe enregistrée.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-success">
                <tr>
                    <th>Nom</th>
                    <th>Niveau</th>
                    <th>Filière</th>
                    <th>Année académique</th>
                    <th class="text-center">Capacité max.</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Classes)
                {
                    <tr>
                        <td>@c.Nom</td>
                        <td><span class="badge bg-success">@c.Niveau</span></td>
                        <td>@c.Filiere</td>
                        <td>@c.AnneeAcademique</td>
                        <td class="text-center">@c.CapaciteMax</td>
                        <td class="text-end">
                            <a asp-page="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-warning">Éditer</a>
                            <a asp-page="Delete" asp-route-id="@c.Id" class="btn btn-sm btn-outline-danger">Supprimer</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
