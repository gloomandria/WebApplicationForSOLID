@page "{id:int}"
@model WebApplicationForSOLID.Pages.Enseignants.DeleteModel
@{
    ViewData["Title"] = "Supprimer l'enseignant";
}

<h1 class="text-danger">🗑️ Supprimer l'enseignant</h1>

<div class="alert alert-warning mt-3">
    Êtes-vous sûr de vouloir supprimer <strong>@Model.Enseignant.NomComplet</strong> (@Model.Enseignant.Matricule) ?
</div>

<form method="post" class="d-flex gap-2">
    <button type="submit" class="btn btn-danger">Confirmer</button>
    <a asp-page="Index" class="btn btn-secondary">Annuler</a>
</form>
