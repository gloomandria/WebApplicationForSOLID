@page
@model WebApplicationForSOLID.Pages.Enseignants.CreateModel
@using WebApplicationForSOLID.Domain.Models
@{
    ViewData["Title"] = "Nouvel enseignant";
}

<h1>👩‍🏫 Nouvel enseignant</h1>

<form method="post" class="mt-3" style="max-width:560px">
    <div asp-validation-summary="All" class="alert alert-danger" style="display:@(ViewContext.ModelState.IsValid ? "none" : "block")"></div>

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Enseignant.Nom" class="form-label"></label>
            <input asp-for="Enseignant.Nom" class="form-control" />
        </div>
        <div class="col-md-6">
            <label asp-for="Enseignant.Prenom" class="form-label"></label>
            <input asp-for="Enseignant.Prenom" class="form-control" />
        </div>
        <div class="col-md-8">
            <label asp-for="Enseignant.Email" class="form-label"></label>
            <input asp-for="Enseignant.Email" class="form-control" type="email" />
        </div>
        <div class="col-md-4">
            <label asp-for="Enseignant.Telephone" class="form-label"></label>
            <input asp-for="Enseignant.Telephone" class="form-control" />
        </div>
        <div class="col-md-6">
            <label asp-for="Enseignant.Specialite" class="form-label"></label>
            <input asp-for="Enseignant.Specialite" class="form-control" />
        </div>
        <div class="col-md-6">
            <label asp-for="Enseignant.Grade" class="form-label"></label>
            <select asp-for="Enseignant.Grade" class="form-select"
                    asp-items="Html.GetEnumSelectList<GradeEnseignant>()"></select>
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-success">Créer</button>
        <a asp-page="Index" class="btn btn-secondary">Annuler</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
