@page "{id:int}"
@model ProjetScolariteSOLID.Pages.Matieres.EditModel
@{
    ViewData["Title"] = "Modifier la matière";
}

<h1>✏️ Modifier la matière</h1>

<form method="post" class="mt-3" style="max-width:560px">
    <div asp-validation-summary="All" class="alert alert-danger" style="display:@(ViewContext.ModelState.IsValid ? "none" : "block")"></div>

    <input asp-for="Matiere.Id" type="hidden" />

    <div class="row g-3">
        <div class="col-md-4">
            <label asp-for="Matiere.Code" class="form-label"></label>
            <input asp-for="Matiere.Code" class="form-control" />
        </div>
        <div class="col-md-8">
            <label asp-for="Matiere.Intitule" class="form-label"></label>
            <input asp-for="Matiere.Intitule" class="form-control" />
        </div>
        <div class="col-12">
            <label asp-for="Matiere.Description" class="form-label"></label>
            <textarea asp-for="Matiere.Description" class="form-control" rows="2"></textarea>
        </div>
        <div class="col-md-4">
            <label asp-for="Matiere.Coefficient" class="form-label"></label>
            <input asp-for="Matiere.Coefficient" class="form-control" type="number" min="1" />
        </div>
        <div class="col-md-4">
            <label asp-for="Matiere.VolumeHoraire" class="form-label"></label>
            <input asp-for="Matiere.VolumeHoraire" class="form-control" type="number" min="0" />
        </div>
        <div class="col-md-4">
            <label asp-for="Matiere.EnseignantId" class="form-label"></label>
            <select asp-for="Matiere.EnseignantId" asp-items="Model.EnseignantsList" class="form-select">
                <option value="">— Aucun —</option>
            </select>
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-warning">Enregistrer</button>
        <a asp-page="Index" class="btn btn-secondary">Annuler</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
