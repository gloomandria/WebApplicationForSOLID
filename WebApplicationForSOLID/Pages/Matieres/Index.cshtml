@page
@model ProjetScolariteSOLID.Pages.Matieres.IndexModel
@{
    ViewData["Title"] = "Matières";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>📚 Matières</h1>
    <a asp-page="Create" class="btn btn-warning">+ Nouvelle matière</a>
</div>

@if (!Model.Matieres.Any())
{
    <div class="alert alert-info">Aucune matière enregistrée.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-warning">
                <tr>
                    <th>Code</th>
                    <th>Intitulé</th>
                    <th class="text-center">Coefficient</th>
                    <th class="text-center">Volume horaire</th>
                    <th>Enseignant</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model.Matieres)
                {
                    <tr>
                        <td><code>@m.Code</code></td>
                        <td>@m.Intitule</td>
                        <td class="text-center"><span class="badge bg-warning text-dark">@m.Coefficient</span></td>
                        <td class="text-center">@m.VolumeHoraire h</td>
                        <td>@(m.Enseignant?.NomComplet ?? "—")</td>
                        <td class="text-end">
                            <a asp-page="Edit" asp-route-id="@m.Id" class="btn btn-sm btn-outline-warning">Éditer</a>
                            <a asp-page="Delete" asp-route-id="@m.Id" class="btn btn-sm btn-outline-danger">Supprimer</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
