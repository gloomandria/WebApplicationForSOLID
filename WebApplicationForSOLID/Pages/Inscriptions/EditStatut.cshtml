@page "{id:int}"
@model ProjetScolariteSOLID.Pages.Inscriptions.EditStatutModel
@{
    ViewData["Title"] = "Modifier le statut";
}

<h1>✏️ Modifier le statut de l'inscription</h1>

<dl class="row mt-3" style="max-width:400px">
    <dt class="col-sm-5">Étudiant</dt>
    <dd class="col-sm-7">@(Model.Inscription.Etudiant?.NomComplet ?? $"Id={Model.Inscription.EtudiantId}")</dd>
    <dt class="col-sm-5">Classe</dt>
    <dd class="col-sm-7">@(Model.Inscription.Classe?.Nom ?? $"Id={Model.Inscription.ClasseId}")</dd>
    <dt class="col-sm-5">Date</dt>
    <dd class="col-sm-7">@Model.Inscription.DateInscription.ToString("dd/MM/yyyy")</dd>
</dl>

<form method="post" style="max-width:320px">
    <input type="hidden" asp-for="InscriptionId" />
    <div class="mb-3">
        <label asp-for="StatutId" class="form-label">Nouveau statut</label>
        <select asp-for="StatutId" asp-items="Model.StatutsList" class="form-select"></select>
    </div>
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-warning">Enregistrer</button>
        <a asp-page="Index" class="btn btn-secondary">Annuler</a>
    </div>
</form>
