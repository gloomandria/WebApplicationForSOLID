@page
@model ProjetScolariteSOLID.Pages.Inscriptions.CreateModel
@{
    ViewData["Title"] = "Nouvelle inscription";
}

<h1>📋 Nouvelle inscription</h1>

<form method="post" class="mt-3" style="max-width:480px">
    <div asp-validation-summary="All" class="alert alert-danger" style="display:@(ViewContext.ModelState.IsValid ? "none" : "block")"></div>

    <div class="mb-3">
        <label asp-for="EtudiantId" class="form-label">Étudiant</label>
        <select asp-for="EtudiantId" asp-items="Model.EtudiantsList" class="form-select">
            <option value="">— Choisir un étudiant —</option>
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="ClasseId" class="form-label">Classe</label>
        <select asp-for="ClasseId" asp-items="Model.ClassesList" class="form-select">
            <option value="">— Choisir une classe —</option>
        </select>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Inscrire</button>
        <a asp-page="Index" class="btn btn-secondary">Annuler</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
