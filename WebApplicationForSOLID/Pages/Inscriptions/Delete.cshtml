@page "{id:int}"
@model ProjetScolariteSOLID.Pages.Inscriptions.DeleteModel
@{
    ViewData["Title"] = "Supprimer l'inscription";
}

<h1 class="text-danger">🗑️ Supprimer l'inscription</h1>

<div class="alert alert-warning mt-3">
    Êtes-vous sûr de vouloir supprimer cette inscription ? Cette action est irréversible.
</div>

<dl class="row" style="max-width:400px">
    <dt class="col-sm-5">Étudiant</dt>
    <dd class="col-sm-7">@(Model.Inscription.Etudiant?.NomComplet ?? $"Id={Model.Inscription.EtudiantId}")</dd>
    <dt class="col-sm-5">Classe</dt>
    <dd class="col-sm-7">@(Model.Inscription.Classe?.Nom ?? $"Id={Model.Inscription.ClasseId}")</dd>
    <dt class="col-sm-5">Date</dt>
    <dd class="col-sm-7">@Model.Inscription.DateInscription.ToString("dd/MM/yyyy")</dd>
    <dt class="col-sm-5">Statut</dt>
    <dd class="col-sm-7">@Model.Inscription.Statut</dd>
</dl>

<form method="post" class="d-flex gap-2">
    <button type="submit" class="btn btn-danger">Confirmer la suppression</button>
    <a asp-page="Index" class="btn btn-secondary">Annuler</a>
</form>
