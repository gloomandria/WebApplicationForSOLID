@page
@model ProjetScolariteSOLID.Pages.Inscriptions.IndexModel
@{
    ViewData["Title"] = "Inscriptions";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>📋 Inscriptions</h1>
    <a asp-page="Create" class="btn btn-primary">+ Nouvelle inscription</a>
</div>

@if (!Model.Inscriptions.Items.Any())
{
    <div class="alert alert-info">Aucune inscription enregistrée.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-primary">
                <tr>
                    <th>Étudiant</th>
                    <th>Classe</th>
                    <th>Date d'inscription</th>
                    <th>Statut</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var i in Model.Inscriptions.Items)
                {
                    <tr>
                        <td>@(i.Etudiant?.NomComplet ?? $"Id={i.EtudiantId}")</td>
                        <td>@(i.Classe?.Nom ?? $"Id={i.ClasseId}")</td>
                        <td>@i.DateInscription.ToString("dd/MM/yyyy")</td>
                        <td>
                            @{
                                    var libelle    = i.Statut?.Libelle ?? "";
                                    var badgeClass = libelle switch
                                    {
                                        "Active"    => "bg-success",
                                        "Suspendue" => "bg-warning text-dark",
                                        _           => "bg-danger"
                                    };
                                }
                                <span class="badge @badgeClass">@libelle</span>
                        </td>
                        <td class="text-end">
                            <a asp-page="EditStatut" asp-route-id="@i.Id" class="btn btn-sm btn-outline-warning">Statut</a>
                            <a asp-page="Delete" asp-route-id="@i.Id" class="btn btn-sm btn-outline-danger">Supprimer</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center">
        <small class="text-muted">@Model.Inscriptions.TotalCount inscription(s) — Page @Model.Inscriptions.Page / @Model.Inscriptions.TotalPages</small>
        <nav>
            <ul class="pagination mb-0">
                @if (Model.Inscriptions.HasPreviousPage)
                {
                    <li class="page-item">
                        <a class="page-link" asp-page="Index" asp-route-currentPage="@(Model.CurrentPage - 1)">‹</a>
                    </li>
                }
                @for (int p = 1; p <= Model.Inscriptions.TotalPages; p++)
                {
                    <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-page="Index" asp-route-currentPage="@p">@p</a>
                    </li>
                }
                @if (Model.Inscriptions.HasNextPage)
                {
                    <li class="page-item">
                        <a class="page-link" asp-page="Index" asp-route-currentPage="@(Model.CurrentPage + 1)">›</a>
                    </li>
                }
            </ul>
        </nav>
    </div>
}
