@page "{id:int}"
@model ProjetScolariteSOLID.Pages.Notes.DeleteModel
@{
    ViewData["Title"] = "Supprimer la note";
}

<h1 class="text-danger">🗑️ Supprimer la note</h1>

<div class="alert alert-warning mt-3">
    Êtes-vous sûr de vouloir supprimer cette note ? Cette action est irréversible.
</div>

<dl class="row" style="max-width:400px">
    <dt class="col-sm-5">Étudiant</dt>
    <dd class="col-sm-7">@(Model.Note.Etudiant?.NomComplet ?? $"Id={Model.Note.EtudiantId}")</dd>
    <dt class="col-sm-5">Matière</dt>
    <dd class="col-sm-7">@(Model.Note.Matiere?.Intitule ?? $"Id={Model.Note.MatiereId}")</dd>
    <dt class="col-sm-5">Valeur</dt>
    <dd class="col-sm-7"><strong>@Model.Note.Valeur.ToString("0.##") / 20</strong></dd>
    <dt class="col-sm-5">Type</dt>
    <dd class="col-sm-7">@Model.Note.TypeEvaluation</dd>
    <dt class="col-sm-5">Date</dt>
    <dd class="col-sm-7">@Model.Note.Date.ToString("dd/MM/yyyy")</dd>
</dl>

<form method="post" class="d-flex gap-2">
    <button type="submit" class="btn btn-danger">Confirmer la suppression</button>
    <a asp-page="Index" class="btn btn-secondary">Annuler</a>
</form>
