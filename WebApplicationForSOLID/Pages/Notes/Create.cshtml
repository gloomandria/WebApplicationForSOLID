@page
@model ProjetScolariteSOLID.Pages.Notes.CreateModel
@{
    ViewData["Title"] = "Ajouter une note";
}

<h1>📝 Ajouter une note</h1>

<form method="post" class="mt-3" style="max-width:560px">
    <div asp-validation-summary="All" class="alert alert-danger" style="display:@(ViewContext.ModelState.IsValid ? "none" : "block")"></div>

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Note.EtudiantId" class="form-label">Étudiant</label>
            <select asp-for="Note.EtudiantId" asp-items="Model.EtudiantsList" class="form-select">
                <option value="">— Choisir —</option>
            </select>
        </div>
        <div class="col-md-6">
            <label asp-for="Note.MatiereId" class="form-label">Matière</label>
            <select asp-for="Note.MatiereId" asp-items="Model.MatieresList" class="form-select">
                <option value="">— Choisir —</option>
            </select>
        </div>
        <div class="col-md-4">
            <label asp-for="Note.Valeur" class="form-label"></label>
            <input asp-for="Note.Valeur" class="form-control" type="number" step="0.01" min="0" max="20" />
        </div>
        <div class="col-md-4">
            <label asp-for="Note.TypeEvaluationId" class="form-label">Type d'évaluation</label>
            <select asp-for="Note.TypeEvaluationId" asp-items="Model.TypesEvalList" class="form-select">
                <option value="">— Choisir —</option>
            </select>
        </div>
        <div class="col-md-4">
            <label asp-for="Note.Date" class="form-label"></label>
            <input asp-for="Note.Date" class="form-control" type="date" />
        </div>
        <div class="col-12">
            <label asp-for="Note.Commentaire" class="form-label"></label>
            <input asp-for="Note.Commentaire" class="form-control" />
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-info text-white">Ajouter</button>
        <a asp-page="Index" class="btn btn-secondary">Annuler</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
