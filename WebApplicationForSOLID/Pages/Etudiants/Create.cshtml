@page
@model WebApplicationForSOLID.Pages.Etudiants.CreateModel
@{
    ViewData["Title"] = "Nouvel étudiant";
}

<h1>👨‍🎓 Nouvel étudiant</h1>

<form method="post" class="mt-3" style="max-width:560px">
    <div asp-validation-summary="All" class="alert alert-danger" style="display:@(ViewContext.ModelState.IsValid ? "none" : "block")"></div>

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Etudiant.Nom" class="form-label"></label>
            <input asp-for="Etudiant.Nom" class="form-control" />
        </div>
        <div class="col-md-6">
            <label asp-for="Etudiant.Prenom" class="form-label"></label>
            <input asp-for="Etudiant.Prenom" class="form-control" />
        </div>
        <div class="col-md-8">
            <label asp-for="Etudiant.Email" class="form-label"></label>
            <input asp-for="Etudiant.Email" class="form-control" type="email" />
        </div>
        <div class="col-md-4">
            <label asp-for="Etudiant.Telephone" class="form-label"></label>
            <input asp-for="Etudiant.Telephone" class="form-control" />
        </div>
        <div class="col-md-6">
            <label asp-for="Etudiant.DateNaissance" class="form-label"></label>
            <input asp-for="Etudiant.DateNaissance" class="form-control" type="date" />
        </div>
        <div class="col-12">
            <label asp-for="Etudiant.Adresse" class="form-label"></label>
            <input asp-for="Etudiant.Adresse" class="form-control" />
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Créer</button>
        <a asp-page="Index" class="btn btn-secondary">Annuler</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
