@{
    ViewData["Title"] = "File d'emails";
}

<div id="app-data" data-controller="Admin"></div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📧 File d'emails</h2>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Back-office</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-hover align-middle" id="dt-emailqueue">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Destinataire</th>
                <th>Sujet</th>
                <th>Statut</th>
                <th class="text-center">Tentatives</th>
                <th>Créé le</th>
                <th>Envoyé le</th>
                <th class="nosort">Erreur</th>
            </tr>
        </thead>
        <tbody></tbody>
    </table>
</div>

@section Scripts {
    <script src="~/js/admin-emailqueue.js" asp-append-version="true"></script>
}