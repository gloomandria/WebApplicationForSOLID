@model ProjetScolariteSOLID.ViewModels.EtudiantsViewModel

@if (Model.SelectedEtudiant is not null)
{
    var e = Model.SelectedEtudiant;
    <div class="row g-3">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">Informations personnelles</div>
                <div class="card-body">
                    <dl class="row mb-0 small">
                        <dt class="col-sm-5">N°</dt><dd class="col-sm-7">@e.NumeroEtudiant</dd>
                        <dt class="col-sm-5">Email</dt><dd class="col-sm-7">@e.Email</dd>
                        <dt class="col-sm-5">Téléphone</dt><dd class="col-sm-7">@e.Telephone</dd>
                        <dt class="col-sm-5">Naissance</dt><dd class="col-sm-7">@e.DateNaissance.ToString("dd/MM/yyyy")</dd>
                        <dt class="col-sm-5">Adresse</dt><dd class="col-sm-7">@e.Adresse</dd>
                        <dt class="col-sm-5">Inscrit le</dt><dd class="col-sm-7">@e.DateInscription.ToString("dd/MM/yyyy")</dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            @if (Model.Bulletin is not null && Model.Bulletin.Lignes.Any())
            {
                <div class="card shadow-sm">
                    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                        <span>📊 Bulletin</span>
                        <span class="badge bg-light text-dark">@Model.Bulletin.MoyenneGenerale/20 — @Model.Bulletin.Mention</span>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0">
                            <thead class="table-light"><tr><th>Matière</th><th class="text-center">Coeff.</th><th class="text-center">Moy.</th></tr></thead>
                            <tbody>
                                @foreach (var l in Model.Bulletin.Lignes)
                                {
                                    <tr class="@(l.MoyenneMatiere < 10 ? "table-danger" : "")">
                                        <td>@l.IntituleMatiere</td>
                                        <td class="text-center">@l.Coefficient</td>
                                        <td class="text-center fw-bold">@l.MoyenneMatiere/20</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info">Aucune note disponible.</div>
            }
        </div>
    </div>
}
