@model ProjetScolariteSOLID.ViewModels.EtudiantsViewModel
@{
    ViewData["Title"] = "Étudiants";
}

<div id="app-data"
     data-controller="Etudiants"
     data-current-page="@Model.CurrentPage"></div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>👨‍🎓 Étudiants</h1>
    <button type="button" class="btn btn-primary" id="btn-open-create">+ Nouvel étudiant</button>
</div>

<div id="alert-zone"></div>

<div class="table-responsive">
    <table class="table table-hover align-middle" id="dt-etudiants">
        <thead class="table-primary">
            <tr>
                <th>N° Étudiant</th>
                <th>Nom complet</th>
                <th>Email</th>
                <th>Téléphone</th>
                <th>Date naissance</th>
                <th class="text-end nosort">Actions</th>
            </tr>
        </thead>
        <tbody id="table-body"></tbody>
    </table>
</div>

<!-- Modal : Créer -->
<div class="modal fade" id="modal-create" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">👨‍🎓 Nouvel étudiant</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <form id="form-create">
                @Html.AntiForgeryToken()
                <div class="modal-body" id="modal-create-body"><div class="text-center py-3"><div class="spinner-border spinner-border-sm"></div></div></div>
                <div class="modal-footer">
                    <div id="modal-create-alert" class="text-danger me-auto small"></div>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-primary">Créer</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal : Éditer -->
<div class="modal fade" id="modal-edit" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">✏️ Modifier l'étudiant</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <form id="form-edit">
                @Html.AntiForgeryToken()
                <div class="modal-body" id="modal-edit-body"><div class="text-center py-3"><div class="spinner-border spinner-border-sm"></div></div></div>
                <div class="modal-footer">
                    <div id="modal-edit-alert" class="text-danger me-auto small"></div>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-warning">Enregistrer</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal : Supprimer -->
<div class="modal fade" id="modal-delete" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title text-danger">🗑️ Supprimer l'étudiant</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <form id="form-delete">
                @Html.AntiForgeryToken()
                <div class="modal-body" id="modal-delete-body"><div class="text-center py-3"><div class="spinner-border spinner-border-sm"></div></div></div>
                <div class="modal-footer">
                    <div id="modal-delete-alert" class="text-danger me-auto small"></div>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-danger">Confirmer</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal : Détails -->
<div class="modal fade" id="modal-details" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">👤 Détails</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body" id="modal-details-body"><div class="text-center py-3"><div class="spinner-border spinner-border-sm"></div></div></div>
            <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fermer</button></div>
        </div>
    </div>
</div>

@section Scripts {    <script src="~/js/etudiants.js" asp-append-version="true"></script>
}
