@model ProjetScolariteSOLID.ViewModels.Admin.AuditDetailViewModel
@{
    ViewData["Title"] = $"Audit #{Model.Log.Id}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>🕵️ Audit #@Model.Log.Id</h2>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Journal</a>
</div>

<div class="card mb-3">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Horodatage (UTC)</dt>
            <dd class="col-sm-9">@Model.Log.Timestamp.ToString("dd/MM/yyyy HH:mm:ss")</dd>

            <dt class="col-sm-3">Table</dt>
            <dd class="col-sm-9"><code>@Model.Log.TableName</code></dd>

            <dt class="col-sm-3">Action</dt>
            <dd class="col-sm-9">
                @switch (Model.Log.Action)
                {
                    case "INSERT":
                        <span class="badge bg-success">INSERT</span>
                        break;
                    case "UPDATE":
                        <span class="badge bg-warning text-dark">UPDATE</span>
                        break;
                    case "DELETE":
                        <span class="badge bg-danger">DELETE</span>
                        break;
                    default:
                        <span class="badge bg-secondary">@Model.Log.Action</span>
                        break;
                }
            </dd>

            <dt class="col-sm-3">Clé(s)</dt>
            <dd class="col-sm-9"><code>@Model.Log.KeyValues</code></dd>

            <dt class="col-sm-3">Utilisateur (Id)</dt>
            <dd class="col-sm-9">@(Model.Log.UserId ?? "—")</dd>
        </dl>
    </div>
</div>

<div class="row g-3">
    @if (Model.Log.OldValues is not null)
    {
        <div class="col-md-6">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">Avant (OldValues)</div>
                <div class="card-body p-0">
                    <pre class="m-0 p-3" style="white-space:pre-wrap;font-size:.85rem">@Model.Log.OldValues</pre>
                </div>
            </div>
        </div>
    }
    @if (Model.Log.NewValues is not null)
    {
        <div class="col-md-6">
            <div class="card border-success">
                <div class="card-header bg-success text-white">Après (NewValues)</div>
                <div class="card-body p-0">
                    <pre class="m-0 p-3" style="white-space:pre-wrap;font-size:.85rem">@Model.Log.NewValues</pre>
                </div>
            </div>
        </div>
    }
</div>
