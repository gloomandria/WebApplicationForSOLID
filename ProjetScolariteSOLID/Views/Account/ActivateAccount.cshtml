@model ProjetScolariteSOLID.ViewModels.Auth.ActivateAccountViewModel
@{
    ViewData["Title"] = "Activer votre compte";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="card shadow-sm">
    <div class="card-body p-4">
        <h4 class="fw-bold mb-3">🔑 Activer votre compte</h4>
        <p class="text-muted">Choisissez un mot de passe pour activer votre compte.</p>
        <form asp-action="ActivateAccount" method="post">
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="Token" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>
            <div class="d-grid">
                <button type="submit" class="btn btn-success">Activer mon compte</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
